# =============================================================================
# ProjectCraft — Environment Configuration
# =============================================================================
#
# Quick start:
#   cp .env.local.example frontend/.env.local
#   # Fill in at least one AI key below, then: pnpm install && pnpm dev
#
# Keys are server-only (no NEXT_PUBLIC_ prefix) so they never reach the browser.
# You can also skip the env file and paste keys directly in the in-app
# Model Manager (Studio → Models tab) — they are stored in your browser only.
#
# =============================================================================

# Add API keys (used by Python backend for /api/agent when BYOK not set in browser)
GEMINI_API_KEY=

# Groq  →  https://console.groq.com/keys  (fast, generous free tier)
GROQ_API_KEY=

# --- Optional: override the default model for each provider ---
# GEMINI_MODEL=gemini-2.5-flash-lite
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: web search for agent WEB_SEARCH tool ---
# SERPER_API_KEY=
# BRAVE_SEARCH_API_KEY=

# --- Agent loop (Python backend — Logen-style limits) ---
# AGENT_MAX_TURNS=20
# AGENT_TOOL_RESULT_MAX_CHARS=10000
# AGENT_CONTEXT_WINDOW=128000
# AGENT_DEFAULT_TEMPERATURE=0.2
# AGENT_DEFAULT_MAX_TOKENS=8192

# --- Backend (Python FastAPI on port 8000) ---
BACKEND_URL=http://localhost:8000
# CORS_ORIGINS=http://localhost:3000

# --- Studio workspace data (Python backend) ---
# PROJECTCRAFT_DATA_PATH=/absolute/path/to/data/studio

# --- Optional: app branding / links ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ProjectCraft
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/projectcraft

# --- Local / self-hosted AI (e.g. Ollama) ---
# Use the in-app Model Manager to add a "Custom" provider with:
#   Base URL: http://localhost:11434/v1   Model: qwen2.5-coder:7b
# No env variable needed for custom/local providers.

# Health check: http://localhost:3000/api/health
